---
// Starlight（docs）にも言語別のOGP画像を出すためのHeadオーバーライド。
// 画像はLP/ブログと共用（scripts/gen-og.mjs で生成）
import Default from '@astrojs/starlight/components/Head.astro';

const { locale } = Astro.locals.starlightRoute;
const site = Astro.site ?? new URL('https://evereapp.com');
const ogImage = new URL(`/og-${locale ?? 'en'}.png`, site);
---

<Default><slot /></Default>
<meta property="og:image" content={ogImage.href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={ogImage.href} />
