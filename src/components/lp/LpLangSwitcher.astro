---
import { LP_LOCALES, LOCALE_LABELS, type LpLocale } from '../../i18n/lp';

interface Props {
	locale: LpLocale;
	label: string;
	up?: boolean;
}

const { locale, label, up = false } = Astro.props;
---

<details class:list={['lp-lang', { 'lp-lang--up': up }]}>
	<summary aria-label={label}>
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
			<circle cx="12" cy="12" r="9.2"></circle>
			<path d="M2.8 12h18.4M12 2.8c2.6 2.5 4 5.7 4 9.2s-1.4 6.7-4 9.2c-2.6-2.5-4-5.7-4-9.2s1.4-6.7 4-9.2z"></path>
		</svg>
		<span class="lp-lang-label">{LOCALE_LABELS[locale]}</span>
	</summary>
	<nav class="lp-lang-menu">
		{LP_LOCALES.map((l) => (
			<a href={`/${l}/`} aria-current={l === locale ? 'true' : undefined}>
				{LOCALE_LABELS[l]}
			</a>
		))}
	</nav>
</details>

<script>
	// 外側クリックで閉じる
	document.querySelectorAll<HTMLDetailsElement>('details.lp-lang').forEach((details) => {
		document.addEventListener('click', (e) => {
			if (details.open && !details.contains(e.target as Node)) details.open = false;
		});
	});
</script>
