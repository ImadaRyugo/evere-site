---
const currencies: [string, string][] = [
	['ﾂ･', 'JPY'],
	['$', 'USD'],
	['竄ｬ', 'EUR'],
	['犧ｿ', 'THB'],
	['竄ｩ', 'KRW'],
	['ﾂ｣', 'GBP'],
	['竄ｫ', 'VND'],
	['竄ｹ', 'INR'],
	['A$', 'AUD'],
	['竄ｱ', 'PHP'],
	['Fr', 'CHF'],
	['竄ｺ', 'TRY'],
];
---

<div class="lp-ticker" aria-hidden="true">
	<div class="lp-ticker-track">
		{[0, 1].map((dup) => (
			<div class="lp-ticker-group" aria-hidden={dup === 1 ? 'true' : undefined}>
				{currencies.map(([sym, code]) => (
					<span class="lp-ticker-item">
						<span class="sym">{sym}</span>
						<span class="code">{code}</span>
						<span class="dot"></span>
					</span>
				))}
			</div>
		))}
	</div>
</div>
