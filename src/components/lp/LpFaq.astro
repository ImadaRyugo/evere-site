---
import type { LpDict } from '../../i18n/lp';

interface Props {
	dict: LpDict;
}

const { dict } = Astro.props;
---

<section class="lp-section" id="faq">
	<div class="lp-container">
		<div style="text-align:center" data-reveal>
			<span class="lp-eyebrow" style="justify-content:center">{dict.faq.eyebrow}</span>
			<h2 class="lp-h2">{dict.faq.title}</h2>
		</div>
		<div class="lp-faq-list">
			{dict.faq.items.map((item, i) => (
				<div class="lp-faq-item" data-reveal>
					<button class="lp-faq-q" type="button" aria-expanded="false" aria-controls={`faq-a-${i}`}>
						{item.q}
						<span class="plus" aria-hidden="true"></span>
					</button>
					<div class="lp-faq-a" id={`faq-a-${i}`}>
						<div><p>{item.a}</p></div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	document.querySelectorAll<HTMLElement>('.lp-faq-item').forEach((item) => {
		const btn = item.querySelector<HTMLButtonElement>('.lp-faq-q');
		btn?.addEventListener('click', () => {
			const open = item.classList.toggle('open');
			btn.setAttribute('aria-expanded', String(open));
		});
	});
</script>
