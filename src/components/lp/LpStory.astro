---
// 「One phone, one story」— Cash App / Apple 方式のピン留めストーリー。
// 画面中央のフォン1台の中で、スクロールに合わせて物語が進む:
//   S0 ヒーロー → S1 記録（カードが積まれる）→ S2 共有（トースト通知）
//   → S3 精算（精算画面へ切替・グラフが伸びる）
// 演出は lp-animations.ts の initStory()。reduced-motion / JS無効時は S0 が静的表示される。
import PhoneMockup from './PhoneMockup.astro';
import AppleBadge from './AppleBadge.astro';
import type { LpLocale, LpDict } from '../../i18n/lp';

interface Props {
	locale: LpLocale;
	dict: LpDict;
}

const { locale, dict } = Astro.props;
---

<section class="lp-story" data-story>
	<div class="lp-story-pin" data-story-pin>
		<canvas class="lp-story-canvas" data-story-canvas aria-hidden="true"></canvas>

		<div class="lp-container lp-story-layout">
			<div class="lp-story-copy">
				<!-- S0: ヒーロー -->
				<div class="lp-scene lp-scene--hero is-active" data-scene="0">
					<h1 class="lp-hero-title">
						{dict.hero.title.map((line) => (
							<span class="line" data-reveal>{line}</span>
						))}
					</h1>
					<p class="lp-hero-sub" data-reveal>{dict.hero.sub}</p>
					<div class="lp-hero-actions" data-reveal>
						<AppleBadge label={dict.hero.cta} locale={locale} />
						<span class="lp-hero-note">{dict.hero.ctaNote}</span>
					</div>
					<!-- SP専用スクロールヒント（PCはピン下部の絶対配置版）。
					     ヒーローの他要素と同じリビールに乗せ、S0退場時はシーンごと消える -->
					<div class="lp-story-hint lp-story-hint--inline" aria-hidden="true" data-reveal>
						<span></span>
					</div>
				</div>

				<!-- S1〜S3: ストーリーシーン -->
				{dict.story.scenes.map((scene, i) => (
					<div class="lp-scene" data-scene={i + 1}>
						<span class="lp-scene-kicker">{scene.kicker}</span>
						<h2 class="lp-scene-title">{scene.title}</h2>
					</div>
				))}
			</div>

			<div class="lp-story-visual" data-hero-visual>
				<div class="lp-phone-scale" data-phone-scale>
					<!-- 起動演出（アイコン→アプリ展開）用のtransform分離ラッパー -->
					<div class="lp-phone-launch" data-phone-launch>
						<PhoneMockup dict={dict} />
					</div>
				</div>
			</div>
		</div>

		<div class="lp-story-progress" data-story-progress aria-hidden="true">
			{[0, 1, 2, 3].map((i) => <i data-dot={i} class:list={[{ active: i === 0 }]}></i>)}
		</div>

		<div class="lp-story-hint" data-story-hint aria-hidden="true">
			<span></span>
		</div>
	</div>
</section>
