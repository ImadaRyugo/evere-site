---
// ルート: 保存済み言語 → ブラウザ言語 → en の順で判定してLPへリダイレクト
// （/privacy と同じ仕組み）
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Bill Splitting App — Evere | Split Expenses Free, No Sign-Up</title>
		<meta
			name="description"
			content="Evere is a bill splitting and expense sharing app. Log who paid and it works out who owes whom — across 162 currencies. Free on iOS, no sign-up needed."
		/>
		<meta name="robots" content="noindex, follow" />
		<!-- SNSクローラーはJSリダイレクトを実行しないため、このページ自体にOGPを持たせる -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Evere" />
		<meta property="og:title" content="Bill Splitting App — Evere | Split Expenses Free, No Sign-Up" />
		<meta
			property="og:description"
			content="Evere is a bill splitting and expense sharing app. Log who paid and it works out who owes whom — across 162 currencies. Free on iOS, no sign-up needed."
		/>
		<meta property="og:url" content="https://evereapp.com/" />
		<meta property="og:image" content="https://evereapp.com/og-en.png" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="Bill Splitting App — Evere | Split Expenses Free, No Sign-Up" />
		<meta
			name="twitter:description"
			content="Evere is a bill splitting and expense sharing app. Log who paid and it works out who owes whom — across 162 currencies. Free on iOS, no sign-up needed."
		/>
		<meta name="twitter:image" content="https://evereapp.com/og-en.png" />
		<meta name="theme-color" content="#f5f5f7" />
		<link rel="icon" href="/favicon.png" />
		<style>
			body {
				margin: 0;
				background: #f5f5f7;
				color: rgba(23, 24, 29, 0.66);
				font-family: -apple-system, BlinkMacSystemFont, sans-serif;
				display: flex;
				align-items: center;
				justify-content: center;
				min-height: 100vh;
			}
		</style>
		<script is:inline>
			(function () {
				const supportedLangs = ['ja', 'en', 'th', 'ko', 'zh-hans', 'zh-hant'];
				const defaultLang = 'en';
				const LANG_STORAGE_KEY = 'evere_preferred_lang';

				function getSavedLanguage() {
					try {
						return localStorage.getItem(LANG_STORAGE_KEY);
					} catch (e) {
						return null;
					}
				}

				function detectLanguage() {
					const savedLang = getSavedLanguage();
					if (savedLang && supportedLangs.includes(savedLang)) return savedLang;

					const browserLangs = navigator.languages || [navigator.language];
					for (const lang of browserLangs) {
						const locale = lang.toLowerCase();
						if (supportedLangs.includes(locale)) return locale;
						const langPrefix = locale.split('-')[0];
						if (supportedLangs.includes(langPrefix)) return langPrefix;
						if (locale.startsWith('zh-')) {
							if (locale.includes('tw') || locale.includes('hk') || locale.includes('hant')) {
								return 'zh-hant';
							}
							return 'zh-hans';
						}
					}
					return defaultLang;
				}

				window.location.replace('/' + detectLanguage() + '/');
			})();
		</script>
		<noscript>
			<meta http-equiv="refresh" content="0; url=/en/" />
		</noscript>
	</head>
	<body>
		<p>Redirecting…</p>
	</body>
</html>
