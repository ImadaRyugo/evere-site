---
// Language detection and redirect page for Privacy Policy (client-side)
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Privacy Policy - Evere</title>
	<meta name="description" content="Privacy Policy for Evere - Multi-currency bill splitting app">
	<meta name="robots" content="noindex, follow">
	<!-- SNSクローラーはJSリダイレクトを実行しないため、このページ自体にOGPを持たせる -->
	<meta property="og:type" content="website">
	<meta property="og:site_name" content="Evere">
	<meta property="og:title" content="Privacy Policy - Evere">
	<meta property="og:description" content="Privacy Policy for Evere - Multi-currency bill splitting app">
	<meta property="og:url" content="https://evereapp.com/privacy">
	<meta property="og:image" content="https://evereapp.com/og-en.png">
	<meta property="og:image:width" content="1200">
	<meta property="og:image:height" content="630">
	<meta name="twitter:card" content="summary_large_image">
	<meta name="twitter:image" content="https://evereapp.com/og-en.png">
	<script>
		// Detect browser language and redirect (with saved preference support)
		(function() {
			const supportedLangs = ['ja', 'en', 'th', 'ko', 'zh-hans', 'zh-hant'];
			const defaultLang = 'en';
			const LANG_STORAGE_KEY = 'evere_preferred_lang';

			function getSavedLanguage() {
				try {
					return localStorage.getItem(LANG_STORAGE_KEY);
				} catch (e) {
					return null;
				}
			}

			function detectLanguage() {
				// 1. Check saved preference first (highest priority)
				const savedLang = getSavedLanguage();
				if (savedLang && supportedLangs.includes(savedLang)) {
					return savedLang;
				}

				// 2. Detect from browser language
				const browserLangs = navigator.languages || [navigator.language || navigator.userLanguage];

				for (const lang of browserLangs) {
					const locale = lang.toLowerCase();

					// Exact match
					if (supportedLangs.includes(locale)) {
						return locale;
					}

					// Language prefix match (e.g., "ja-JP" -> "ja")
					const langPrefix = locale.split('-')[0];
					if (supportedLangs.includes(langPrefix)) {
						return langPrefix;
					}

					// Chinese variants
					if (locale.startsWith('zh-')) {
						if (locale.includes('tw') || locale.includes('hk') || locale.includes('hant')) {
							return 'zh-hant';
						}
						return 'zh-hans';
					}
				}

				return defaultLang;
			}

			const detectedLang = detectLanguage();
			const redirectUrl = `/${detectedLang}/privacy/`;
			window.location.replace(redirectUrl);
		})();
	</script>
	<noscript>
		<meta http-equiv="refresh" content="0; url=/en/privacy/">
	</noscript>
</head>
<body>
	<p>Redirecting to Privacy Policy...</p>
</body>
</html>
