---
// ブログ記事ページ。
// hreflang は「同じ slug の翻訳が実際に存在する言語」だけに出す
// （PageLayout の alternateLocales で上書き）。
import { getCollection, render } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import LpNav from '../../../components/lp/LpNav.astro';
import LpFooter from '../../../components/lp/LpFooter.astro';
import AppleBadge from '../../../components/lp/AppleBadge.astro';
import ctaIcon from '../../../assets/cta-app-icon.png';
import { LP_LOCALES, HTML_LANG, lp, type LpLocale } from '../../../i18n/lp';
import { blogDict, formatDate, estimateReadingMinutes } from '../../../i18n/blog';

export async function getStaticPaths() {
	const entries = await getCollection('blog');
	// slug → 存在する言語一覧（翻訳ペアの hreflang 用）
	const langsBySlug = new Map<string, LpLocale[]>();
	const parsed = entries.map((entry) => {
		const [entryLang, ...rest] = entry.id.split('/');
		const slug = rest.join('/').replace(/\.md$/, '');
		const lang = entryLang as LpLocale;
		langsBySlug.set(slug, [...(langsBySlug.get(slug) ?? []), lang]);
		return { entry, lang, slug };
	});
	return parsed.map(({ entry, lang, slug }) => ({
		params: { lang, slug },
		props: {
			entry,
			// LP_LOCALES の並び順で安定させる
			availableLocales: LP_LOCALES.filter((l) => langsBySlug.get(slug)!.includes(l)),
			// 関連記事: 同言語・自分以外。タグが重なるものを優先し、新しい順で最大3件
			related: parsed
				.filter((p) => p.lang === lang && p.slug !== slug)
				.sort((a, b) => {
					const aShared = a.entry.data.tags.filter((t) => entry.data.tags.includes(t)).length;
					const bShared = b.entry.data.tags.filter((t) => entry.data.tags.includes(t)).length;
					if (aShared !== bShared) return bShared - aShared;
					return b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf();
				})
				.slice(0, 3)
				.map((p) => ({ slug: p.slug, data: p.entry.data })),
		},
	}));
}

const { entry, availableLocales, related } = Astro.props;
const lang = Astro.params.lang as LpLocale;
const slug = Astro.params.slug as string;
const dict = lp[lang];
const t = blogDict[lang];
const { data } = entry;
const { Content, headings } = await render(entry);

const toc = headings.filter((h) => h.depth === 2);
const readingMinutes = estimateReadingMinutes(entry.body ?? '', lang);
const readingLabel = t.readingTime.replace('{n}', String(readingMinutes));

const site = Astro.site ?? new URL('https://evereapp.com');
const canonical = new URL(`/${lang}/blog/${slug}/`, site);

// パンくず。FAQリッチリザルトと違い BreadcrumbList は現在もSERPに表示される
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Evere', item: new URL(`/${lang}/`, site).href },
		{
			'@type': 'ListItem',
			position: 2,
			name: t.heading,
			item: new URL(`/${lang}/blog/`, site).href,
		},
		{ '@type': 'ListItem', position: 3, name: data.title, item: canonical.href },
	],
};

const blogPostingSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: data.title,
	description: data.description,
	inLanguage: HTML_LANG[lang],
	datePublished: data.pubDate.toISOString().slice(0, 10),
	...(data.updatedDate ? { dateModified: data.updatedDate.toISOString().slice(0, 10) } : {}),
	mainEntityOfPage: canonical.href,
	image: new URL('/og.png', site).href,
	author: { '@type': 'Organization', name: 'Evere', url: site.href },
	publisher: {
		'@type': 'Organization',
		name: 'Evere',
		url: site.href,
		logo: { '@type': 'ImageObject', url: new URL('/favicon.png', site).href },
	},
};
---

<PageLayout
	locale={lang}
	{/* 記事は「— Evere」を付けない。約8文字ぶんSERPの表示枠を食い、
	    タイトル末尾が切れるため。ブランドは og:site_name で伝わる */}
	title={data.title}
	description={data.description}
	path={`blog/${slug}`}
	alternateLocales={availableLocales}
	ogType="article"
>
	<Fragment slot="head">
		<meta property="article:published_time" content={data.pubDate.toISOString().slice(0, 10)} />
		{
			data.updatedDate && (
				<meta property="article:modified_time" content={data.updatedDate.toISOString().slice(0, 10)} />
			)
		}
		<script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	</Fragment>

	<LpNav locale={lang} dict={dict} />
	<main class="lp-blog">
		{/* data-hue: 記事のアクセント色。先頭タグの色相をこの記事全体に流す */}
		<article class="lp-container lp-blog-article" data-hue={data.tags[0]}>
			<nav class="lp-blog-crumbs" aria-label="Breadcrumb">
				<a href={`/${lang}/`}>Evere</a>
				<span aria-hidden="true">›</span>
				<a href={`/${lang}/blog/`}>{t.heading}</a>
			</nav>
			<header class="lp-blog-header">
				{data.emoji && <p class="lp-blog-emoji" aria-hidden="true">{data.emoji}</p>}
				<h1>{data.title}</h1>
				<p class="lp-blog-meta">
					<time datetime={data.pubDate.toISOString().slice(0, 10)}>
						{t.published}: {formatDate(data.pubDate, lang)}
					</time>
					{
						data.updatedDate && (
							<time datetime={data.updatedDate.toISOString().slice(0, 10)}>
								{t.updated}: {formatDate(data.updatedDate, lang)}
							</time>
						)
					}
					<span>⏱ {readingLabel}</span>
				</p>
				{
					data.tags.length > 0 && (
						<p class="lp-blog-chips">
							{data.tags.map((tag) => (
								<span class="lp-chip">#{tag}</span>
							))}
						</p>
					)
				}
				<p class="lp-blog-lead">{data.description}</p>
			</header>

			{
				toc.length > 1 && (
					<nav class="lp-blog-toc" aria-label={t.toc}>
						<p class="lp-blog-toc-title">📑 {t.toc}</p>
						<ol>
							{toc.map((h) => (
								<li>
									<a href={`#${h.slug}`}>{h.text}</a>
								</li>
							))}
						</ol>
					</nav>
				)
			}

			<div class="lp-blog-body">
				<Content />
			</div>

			{/* トップページの最終CTAと同じ文言・意匠・バッジを使う（lp.ts の cta を共用） */}
			<aside class="lp-blog-cta">
				<img
					class="lp-blog-cta-icon"
					src={ctaIcon.src}
					width={ctaIcon.width}
					height={ctaIcon.height}
					alt=""
					loading="lazy"
					aria-hidden="true"
				/>
				<h2 class="lp-cta-title">{t.ctaTitle}</h2>
				<p class="lp-cta-sub">{data.ctaSub ?? dict.cta.sub}</p>
				<div class="lp-cta-actions">
					<AppleBadge label={dict.cta.button} locale={lang} />
				</div>
			</aside>

			{
				related.length > 0 && (
					<section class="lp-blog-related">
						<h2>{t.related}</h2>
						<ul>
							{related.map((post) => (
								<li>
									<a
										class="lp-blog-related-card"
										href={`/${lang}/blog/${post.slug}/`}
										data-hue={post.data.tags[0]}
									>
										<span class="lp-blog-related-emoji" aria-hidden="true">
											{post.data.emoji ?? '📄'}
										</span>
										<span class="lp-blog-related-text">
											<span class="lp-blog-related-title">{post.data.title}</span>
											<time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
												{formatDate(post.data.pubDate, lang)}
											</time>
										</span>
									</a>
								</li>
							))}
						</ul>
					</section>
				)
			}

			<p class="lp-blog-back">
				<a href={`/${lang}/blog/`}>← {t.backToList}</a>
			</p>
		</article>
	</main>
	<LpFooter locale={lang} dict={dict} />
</PageLayout>
