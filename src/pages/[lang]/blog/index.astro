---
// ブログ一覧ページ。src/content/blog/{lang}/*.md を新しい順に表示する。
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import LpNav from '../../../components/lp/LpNav.astro';
import LpFooter from '../../../components/lp/LpFooter.astro';
import { LP_LOCALES, lp, type LpLocale } from '../../../i18n/lp';
import { blogDict, formatDate } from '../../../i18n/blog';

export function getStaticPaths() {
	return LP_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as LpLocale;
const dict = lp[lang];
const t = blogDict[lang];

import { estimateReadingMinutes } from '../../../i18n/blog';

const posts = (await getCollection('blog', (entry) => entry.id.startsWith(`${lang}/`)))
	.map((entry) => ({
		slug: entry.id.slice(lang.length + 1).replace(/\.md$/, ''),
		data: entry.data,
		readingLabel: blogDict[lang].readingTime.replace(
			'{n}',
			String(estimateReadingMinutes(entry.body ?? '', lang)),
		),
	}))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<PageLayout
	locale={lang}
	title={`${t.listTitle} — Evere`}
	description={t.listDescription}
	path="blog"
>
	<LpNav locale={lang} dict={dict} />
	<main class="lp-blog">
		<div class="lp-container">
			<h1 class="lp-blog-title">{t.heading}</h1>
			<p class="lp-blog-intro">{t.intro}</p>

			{
				posts.length === 0 ? (
					<p class="lp-blog-empty">{t.empty}</p>
				) : (
					<ul class="lp-blog-list">
						{posts.map((post) => (
							<li>
								{/* data-hue: 先頭タグの色相。カード左のレールと絵文字タイルに効く */}
								<a
									class="lp-blog-card"
									href={`/${lang}/blog/${post.slug}/`}
									data-hue={post.data.tags[0]}
								>
									{post.data.emoji && (
										<span class="lp-blog-card-emoji" aria-hidden="true">
											{post.data.emoji}
										</span>
									)}
									<span class="lp-blog-card-body">
										<span class="lp-blog-card-meta">
											<time datetime={post.data.pubDate.toISOString().slice(0, 10)}>
												{formatDate(post.data.pubDate, lang)}
											</time>
											<span>⏱ {post.readingLabel}</span>
										</span>
										<h2>{post.data.title}</h2>
										<p>{post.data.description}</p>
										{post.data.tags.length > 0 && (
											<span class="lp-blog-chips">
												{post.data.tags.map((tag) => (
													<span class="lp-chip" data-hue={tag}>
														#{tag}
													</span>
												))}
											</span>
										)}
									</span>
								</a>
							</li>
						))}
					</ul>
				)
			}
		</div>
	</main>
	<LpFooter locale={lang} dict={dict} />
</PageLayout>
